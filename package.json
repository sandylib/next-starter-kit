{
  "name": "next-starter-kit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run type-check && npm run lint && npm run test:ci && next build",
    "compile": "next build",
    "start": "next start",
    "clean": "rm -rf .next node_modules coverage",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "test": "NODE_ENV=test vitest run",
    "test:ci": "NODE_ENV=test vitest run --coverage",
    "test:watch": "NODE_ENV=test vitest --watch"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
